{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "env": {
        "NODE_OPTIONS": "--no-warnings"
      },
      "args": [
        "--disable-extensions",
        "--extensionDevelopmentPath=${workspaceFolder}/extension",
        "--enable-proposed-api",
        "pairvoice.pairvoice"
      ],
      "outFiles": ["${workspaceFolder}/extension/out/**/*.js"],
      "preLaunchTask": "npm: compile"
    }
  ]
}
